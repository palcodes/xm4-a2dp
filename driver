#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <fcntl.h>
#include <unistd.h>
#include <linux/input.h>

#define BUFFER_SIZE 512

void print_audio_mode() {
    FILE *fp;
    char buffer[BUFFER_SIZE];

    fp = popen("pactl list cards 2>/dev/null", "r");

    if (!fp) {
        perror("popen");
        return;
    }

    int found = 0;

    while (fgets(buffer, sizeof(buffer), fp)) {

        // PipeWire / PulseAudio profile names
        if (strstr(buffer, "a2dp-sink")) {
            printf("Audio Mode: A2DP\n");
            found = 1;
            break;
        }

        if (strstr(buffer, "handsfree_head_unit") ||
            strstr(buffer, "headset-head-unit")) {
            printf("Audio Mode: HFP/HSP\n");
            found = 1;
            break;
        }
    }

    if (!found) {
        printf("Audio Mode: Unknown\n");
    }

    pclose(fp);
}

int main(int argc, char *argv[]) {

    if (argc != 2) {
        printf("usage: %s /dev/input/eventX\n", argv[0]);
        return 1;
    }

    // Print audio mode once at startup
    print_audio_mode();

    // Open Linux input device
    int fd = open(argv[1], O_RDONLY);

    if (fd < 0) {
        perror("open");
        return 1;
    }

    printf("Listening for XM4 events...\n\n");

    struct input_event ev;

    while (1) {

        ssize_t bytes = read(fd, &ev, sizeof(ev));

        if (bytes != sizeof(ev)) {
            perror("read");
            close(fd);
            return 1;
        }

        printf(
            "time %ld.%06ld  type %-3u code %-3u value %-3d\n",
            ev.time.tv_sec,
            ev.time.tv_usec,
            ev.type,
            ev.code,
            ev.value
        );

        fflush(stdout);
    }

    close(fd);

    return 0;
}
